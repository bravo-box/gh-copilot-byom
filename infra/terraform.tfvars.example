# -----------------------------------------------------------------------
# terraform.tfvars.example
#
# Copy this file to terraform.tfvars, fill in required values, and run:
#   ./scripts/deploy.sh -f infra/terraform.tfvars
#
# Before the first deploy, accept the Windows DSVM marketplace image terms
# once per subscription:
#   az vm image terms accept \
#     --publisher microsoft-dsvm \
#     --offer     dsvm-win-2022 \
#     --plan      winserver-2022
#
# -----------------------------------------------------------------------
# Cloud environment selection
# -----------------------------------------------------------------------
# Azure Government (default):
#   export ARM_ENVIRONMENT=usgovernment
#   az cloud set --name AzureUSGovernment
#   ./scripts/deploy.sh --cloud AzureUSGovernment -f infra/terraform.tfvars
#
# Azure Commercial:
#   export ARM_ENVIRONMENT=public
#   az cloud set --name AzureCloud
#   ./scripts/deploy.sh --cloud AzureCloud -f infra/terraform.tfvars
#
# Alternatively, ensure the following env vars are set for SP auth:
#   export ARM_SUBSCRIPTION_ID=<your-subscription-id>
#   export ARM_TENANT_ID=<your-tenant-id>
#   export ARM_CLIENT_ID=<your-service-principal-app-id>       # if using SP
#   export ARM_CLIENT_SECRET=<your-service-principal-secret>   # if using SP
# -----------------------------------------------------------------------

# Required – lowercase letters, numbers, and hyphens only (no spaces)
project_name = "myproject"

# Cloud environment: 'usgovernment' (Azure Government) or 'public' (Azure Commercial)
# Defaults to 'usgovernment' if not set.
# azure_environment = "usgovernment"

# Region – defaults to usgovarizona for Azure Government.
# For Azure Commercial, use a standard region such as eastus.
# location = "usgovarizona"

# Windows Data Science VM credentials
vm_admin_username = "dsadmin"
vm_admin_password = "CHANGE_ME_SuperSecure1!"   # must meet Azure complexity rules

# Optional – use a custom Packer image instead of the marketplace DSVM
# custom_vm_image_id = "/subscriptions/<sub-id>/resourceGroups/rg-byom-dev/providers/Microsoft.Compute/images/dsvm-copilot-image"

# Optional overrides
# vm_size                  = "Standard_DS3_v2"
# aoai_sku                 = "S0"
# model_deployment_name    = "gpt-52"
# model_token_capacity           = 290
# storage_replication_type = "LRS"
